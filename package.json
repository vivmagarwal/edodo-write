{
  "name": "edodo-write",
  "version": "0.3.0",
  "type": "module",
  "description": "A Notion/Medium-style WYSIWYG editor whose single source of truth is Markdown. Type-to-format, a slash menu, a floating selection toolbar \u2014 framework-agnostic core with an optional React wrapper.",
  "license": "MIT",
  "author": "vivmagarwal",
  "homepage": "https://vivmagarwal.github.io/edodo-write/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vivmagarwal/edodo-write.git"
  },
  "bugs": {
    "url": "https://github.com/vivmagarwal/edodo-write/issues"
  },
  "keywords": [
    "markdown",
    "editor",
    "wysiwyg",
    "rich-text",
    "notion",
    "medium",
    "contenteditable",
    "react",
    "markdown-editor",
    "slash-menu"
  ],
  "main": "./dist-lib/index.js",
  "module": "./dist-lib/index.js",
  "types": "./dist-lib/lib/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist-lib/lib/index.d.ts",
      "import": "./dist-lib/index.js"
    },
    "./react": {
      "types": "./dist-lib/lib/react.d.ts",
      "import": "./dist-lib/react.js"
    },
    "./plugins": {
      "types": "./dist-lib/plugins/index.d.ts",
      "import": "./dist-lib/plugins.js"
    },
    "./testing": {
      "types": "./dist-lib/lib/testing.d.ts",
      "import": "./dist-lib/testing.js"
    },
    "./styles.css": "./dist-lib/edodo-write.css",
    "./package.json": "./package.json"
  },
  "files": [
    "dist-lib",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "dev": "vite",
    "gen:llms": "node scripts/gen-llms-txt.mjs",
    "prebuild": "node scripts/gen-llms-txt.mjs",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "build:types": "tsc -p tsconfig.lib.json",
    "build:pkg": "npm run build:lib && npm run build:types",
    "preview": "vite preview --port 4183 --strictPort",
    "typecheck": "tsc -b --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build:pkg",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@joplin/turndown-plugin-gfm": "^1.0.61",
    "marked": "^12.0.2",
    "turndown": "^7.2.0"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "react-dom": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^4.3.4",
    "jsdom": "^25.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  },
  "sideEffects": [
    "**/*.css"
  ]
}
