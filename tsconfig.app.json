{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "baseUrl": ".",
    "paths": {
      "@core/*": ["src/core/*"],
      "edodo-write": ["src/lib/index.ts"],
      "edodo-write/react": ["src/lib/react.tsx"],
      "edodo-write/plugins": ["src/plugins/index.ts"],
      "edodo-write/testing": ["src/lib/testing.ts"],
      "edodo-write/parse": ["src/lib/parse-api.ts"],
      "edodo-write/email": ["src/lib/email.ts"],
      "edodo-write/ingest": ["src/lib/ingest.ts"],
      "edodo-write/styles.css": ["src/styles.css"]
    }
  },
  "include": ["src", "tests"]
}
